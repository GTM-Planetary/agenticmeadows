# AgenticMeadows — Environment Variables
# Copy this file to .env and adjust values for your environment.
# All defaults work out-of-the-box for local Docker Compose usage.

# ── Database ────────────────────────────────────────────────
DB_USER=turf
DB_PASSWORD=turf_local
DB_NAME=turfmindai
# Used by Prisma inside the backend container (do not change unless you change compose networking)
DATABASE_URL=postgresql://turf:turf_local@db:5432/turfmindai

# ── Authentication ───────────────────────────────────────────
# IMPORTANT: Change this before any non-local deployment
JWT_SECRET=change-me-in-production-min-32-chars!!

# ── Service Ports (host-side) ────────────────────────────────
FRONTEND_PORT=3001
BACKEND_PORT=4000
AI_PORT=8000
DB_PORT=5433
OLLAMA_PORT=11435

# ── Runtime ─────────────────────────────────────────────────
NODE_ENV=development

# ── Frontend (build-time Vite env vars) ──────────────────────
# These are baked into the frontend build at docker-compose build time.
# When running locally outside Docker (npm run dev), they must be in frontend/.env
VITE_API_BASE_URL=http://localhost:4000
VITE_AI_BASE_URL=http://localhost:8000
